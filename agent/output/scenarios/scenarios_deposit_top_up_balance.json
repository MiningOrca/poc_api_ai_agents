{
  "endpointId": "deposit_top_up_balance",
  "scenarios": [
    {
      "title": "Deposit valid amount to existing user",
      "category": "positive",
      "mode": "chain",
      "expectedStatusCode": 200,
      "sourceRefs": [
        "userId: required, must refer to an existing user",
        "amount: required, number > 0, up to two decimal places",
        "currency: currently only \"EUR\" is supported",
        "200"
      ],
      "setupReason": "A user must exist before depositing; no pre-existing user is guaranteed in initial state.",
      "steps": [
        {
          "kind": "single",
          "times": 1,
          "index": 0,
          "endIndex": 0,
          "endpointId": "create_user",
          "stepRole": "setup",
          "contractRef": {
            "method": "POST",
            "path": "/users"
          },
          "inputStep": {
            "endpointId": "create_user",
            "stepRole": "setup",
            "stepName": "setup_1_create_user",
            "consumesContext": []
          },
          "outputContextPlan": [
            {
              "contextKey": "user_id",
              "requiredForNextSteps": true
            }
          ],
          "executionDraft": {
            "stepSummary": "Create a user with email $${random_email_user} and name $${random_str_user}",
            "pathParams": {},
            "queryParams": {},
            "body": {
              "email": "$${random_email_user}",
              "name": "$${random_str_user}"
            },
            "fieldAssertions": [
              {
                "path": "$.email",
                "operator": "equals",
                "expected": "$${random_email_user}"
              }
            ],
            "produceBinding": [
              {
                "contextKey": "user_id",
                "sourcePath": "$.userId"
              }
            ]
          },
          "expect": {
            "statusCode": 201,
            "requiredFields": [
              "email",
              "name",
              "userId"
            ],
            "fieldAssertions": [
              {
                "path": "$.email",
                "operator": "equals",
                "expected": "$${random_email_user}"
              }
            ]
          }
        },
        {
          "kind": "single",
          "times": 1,
          "index": 1,
          "endIndex": 1,
          "endpointId": "deposit_top_up_balance",
          "stepRole": "target",
          "contractRef": {
            "method": "POST",
            "path": "/wallets/deposit"
          },
          "inputStep": {
            "endpointId": "deposit_top_up_balance",
            "stepRole": "target",
            "stepName": "target_2_deposit_top_up_balance",
            "consumesContext": [
              "user_id"
            ]
          },
          "outputContextPlan": [],
          "executionDraft": {
            "stepSummary": "Deposit 100.00 EUR to user $${user_id}",
            "pathParams": {},
            "queryParams": {},
            "body": {
              "amount": 100.0,
              "currency": "EUR",
              "userId": "$${user_id}"
            },
            "fieldAssertions": [
              {
                "path": "$.currency",
                "operator": "equals",
                "expected": "EUR"
              },
              {
                "path": "$.userId",
                "operator": "equals",
                "expected": "$${user_id}"
              }
            ],
            "produceBinding": []
          },
          "expect": {
            "statusCode": 200,
            "requiredFields": [
              "currency",
              "newBalance",
              "userId"
            ],
            "fieldAssertions": [
              {
                "path": "$.currency",
                "operator": "equals",
                "expected": "EUR"
              },
              {
                "path": "$.userId",
                "operator": "equals",
                "expected": "$${user_id}"
              }
            ]
          }
        }
      ],
      "parentTestCaseId": "TC-DEPOSIT-TOP-UP-BALANCE-1",
